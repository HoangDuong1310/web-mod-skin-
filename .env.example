# Database
DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Site Configuration (Optional - will use sensible defaults if not set)
NEXT_PUBLIC_SITE_NAME="My Website"
NEXT_PUBLIC_SITE_DESCRIPTION="A modern web application"
NEXT_PUBLIC_SITE_URL="https://example.com"
NEXT_PUBLIC_CONTACT_EMAIL="contact@example.com"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
NEXT_PUBLIC_FROM_NAME="My Website"

# Legacy environment variables (still supported)
APP_NAME="My Website"
APP_DESCRIPTION="A modern web application"
APP_URL="https://example.com"

# Deployment URLs (auto-detected)
# VERCEL_URL - automatically set by Vercel
# RAILWAY_PUBLIC_DOMAIN - automatically set by Railway

# Email Configuration (Optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Cloudflare R2 Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="modskinslol"
R2_PUBLIC_URL="https://cdn.modskinslol.com"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
FACEBOOK_PIXEL_ID=""

# Party Mode Relay Server
AINZ_RELAY_ADMIN_URL="http://your-domain.com:8766"
AINZ_RELAY_ADMIN_KEY="your-secret-admin-key"
NEXT_PUBLIC_AINZ_RELAY_WS_URL="ws://your-domain.com:8765"